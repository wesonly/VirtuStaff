{
  "name": "virtustaff-backend",
  "version": "0.1.0",
  "private": true,
  "description": "VirtuStaff platform backend — AI workforce for SMBs",
  "type": "module",
  "engines": {
    "node": ">=20.0.0"
  },
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "tsc",
    "start": "node dist/index.js",
    "lint": "biome check src/",
    "lint:fix": "biome check --apply src/",
    "format": "biome format --write src/",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "drizzle-kit migrate",
    "db:push": "drizzle-kit push",
    "db:studio": "drizzle-kit studio",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.24.0",
    "@clerk/clerk-sdk-node": "^5.0.0",
    "@hono/node-server": "^2.0.9",
    "@hono/zod-validator": "^0.2.0",
    "bullmq": "^5.0.0",
    "dotenv": "^16.4.0",
    "drizzle-orm": "^0.30.0",
    "hono": "^4.4.0",
    "ioredis": "^5.4.0",
    "jose": "^5.2.0",
    "jsonwebtoken": "^9.0.0",
    "openai": "^4.47.0",
    "pino": "^9.0.0",
    "pino-pretty": "^11.0.0",
    "postgres": "^3.4.0",
    "stripe": "^15.0.0",
    "twilio": "^5.0.0",
    "uuid": "^9.0.0",
    "zod": "^3.23.0"
  },
  "devDependencies": {
    "@biomejs/biome": "^1.7.0",
    "@types/jsonwebtoken": "^9.0.0",
    "@types/node": "^20.12.0",
    "@types/uuid": "^9.0.0",
    "@vitest/coverage-v8": "^1.5.0",
    "drizzle-kit": "^0.21.0",
    "tsx": "^4.23.1",
    "typescript": "^5.9.3",
    "vitest": "^1.5.0"
  }
}
