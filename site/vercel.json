{
  "buildCommand": "vite build",
  "outputDirectory": "dist/client",
  "framework": null,
  "installCommand": "npm install",
  "rewrites": [
    {
      "source": "/api/v1/(.*)",
      "destination": "/api/v1/[...slug]"
    },
    {
      "source": "/(.*)",
      "destination": "/api/ssr"
    }
  ]
}